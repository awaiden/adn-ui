{
	"name": "adn-ui",
	"private": true,
	"description": "A modern, accessible, and cross-framework UI library built with Radix UI, Bits UI, Reka UI, Tailwind CSS v4, and Tailwind Variants.",
	"homepage": "https://github.com/awaiden/adn-ui#readme",
	"bugs": {
		"url": "https://github.com/awaiden/adn-ui/issues"
	},
	"license": "MIT",
	"author": "awaiden (https://github.com/awaiden)",
	"repository": {
		"type": "git",
		"url": "https://github.com/awaiden/adn-ui.git"
	},
	"workspaces": [
		"packages/*",
		"apps/*",
		"examples/*"
	],
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"check": "biome check .",
		"check:fix": "biome check . --write",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@changesets/cli": "^2.30.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"tsdown": "^0.21.2",
		"turbo": "^2.8.14",
		"unplugin-vue": "^7.1.1",
		"vue-tsc": "^3.2.5"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"biome check . --write"
		]
	},
	"packageManager": "bun@1.3.9",
	"dependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"tailwindcss": "^4.2.1"
	}
}
