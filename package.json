{
  "name": "adn-ui",
  "version": "0.1.0",
  "description": "A shadcn registry of accessible React components built with Radix UI, Tailwind CSS v4, and tailwind-variants",
  "keywords": [
    "components",
    "design-system",
    "radix-ui",
    "react",
    "registry",
    "shadcn",
    "tailwindcss",
    "ui"
  ],
  "homepage": "https://github.com/awaiden/adn-ui",
  "license": "MIT",
  "author": "awaiden",
  "repository": {
    "type": "git",
    "url": "https://github.com/awaiden/adn-ui.git"
  },
  "type": "module",
  "scripts": {
    "prebuild": "npx shadcn@latest build",
    "build": "tsc -b && vite build",
    "build-storybook": "storybook build",
    "dev": "vite",
    "format": "oxfmt",
    "lint": "oxlint",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint-plugin-perfectionist": "^5.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "shadcn": "^4.8.3",
    "storybook": "^10.4.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-tailwind-ref": "^1.0.0",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint",
      "oxfmt"
    ]
  }
}
