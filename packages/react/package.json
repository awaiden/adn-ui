  },
  "dependencies": {
    "@adn-ui/core": "workspace:*",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3"
  },
  "devDependencies": {
    "@adn-ui/styles": "workspace:*",
    "@storybook/addon-themes": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.2.19",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite-plus": "^0.1.11",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "bun": ">=1.3.9",
    "node": ">=20.0.0"
