{
  "name": "@adn-ui/react",
  "version": "0.0.1-canary.0",
  "description": "Accessible, themeable React UI components built on Radix UI and Tailwind CSS v4.",
  "keywords": [
    "accessible",
    "adn-ui",
    "components",
    "design-system",
    "radix-ui",
    "react",
    "tailwindcss",
    "ui"
  ],
  "homepage": "https://github.com/awaiden/adn-ui/tree/main/packages/react#readme",
  "bugs": {
