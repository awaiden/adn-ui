  },
  "license": "MIT",
  "author": "awaiden (https://github.com/awaiden)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awaiden/adn-ui.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
