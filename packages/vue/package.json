{
	"name": "@adn-ui/vue",
	"version": "0.0.0",
	"description": "Accessible, themeable Vue 3 UI components built on Reka UI and Tailwind CSS v4.",
	"keywords": [
		"adn-ui",
		"design-system",
		"vue",
		"vue-3",
		"reka-ui",
		"tailwindcss",
		"ui",
		"components"
	],
	"homepage": "https://github.com/awaiden/adn-ui/tree/main/packages/vue#readme",
	"bugs": {
		"url": "https://github.com/awaiden/adn-ui/issues"
	},
	"license": "MIT",
	"author": "awaiden (https://github.com/awaiden)",
	"repository": {
		"type": "git",
		"url": "https://github.com/awaiden/adn-ui.git",
		"directory": "packages/vue"
	},
	"sideEffects": false,
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./styles": {
			"import": "./dist/index.css"
		}
	},
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"test": "vitest",
		"storybook": "BROWSER=none storybook dev -p 6009",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@adn-ui/core": "workspace:*",
		"@adn-ui/styles": "workspace:*",
		"lucide-vue-next": "^0.577.0",
		"reka-ui": "^1.4.3",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@vitejs/plugin-vue": "^6.0.0",
		"@vue/tsconfig": "^0.7.0",
		"storybook": "^10.2.16",
		"tailwindcss": "^4.2.1",
		"tsdown": "^0.21.2",
		"typescript": "~5.9.3",
		"vite": "7",
		"vitest": "^4.0.18",
		"vue": "^3.5.13",
		"vue-tsc": "^3.2.5"
	},
	"peerDependencies": {
		"vue": "^3.5.0",
		"tailwindcss": "^4.0.0"
	}
}
