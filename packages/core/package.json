{
	"name": "@adn-ui/core",
	"version": "0.0.0",
	"description": "Shared styling variants and logic for adn-ui, built with tailwind-variants.",
	"keywords": [
		"adn-ui",
		"design-system",
		"tailwind-variants",
		"styling",
		"variants"
	],
	"homepage": "https://github.com/awaiden/adn-ui/tree/main/packages/core#readme",
	"bugs": {
		"url": "https://github.com/awaiden/adn-ui/issues"
	},
	"license": "MIT",
	"author": "awaiden (https://github.com/awaiden)",
	"repository": {
		"type": "git",
		"url": "https://github.com/awaiden/adn-ui.git",
		"directory": "packages/core"
	},
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown"
	},
	"exports": {
